{
  "manifest_version": 2,
  "name": "IncoBills",
  "description": "AI-powered invoice detection — automatically finds and organizes invoice emails across all your Thunderbird accounts.",
  "version": "1.1.0",
  "author": "ServerSpan",
  "homepage_url": "https://github.com/serverspan/incobills",
  "browser_specific_settings": {
    "gecko": {
      "id": "incobills@serverspan.com",
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "background": {
    "scripts": [
      "shared/constants.js",
      "shared/storage.js",
      "shared/saga-constants.js",
      "background/classifiers/keywords.js",
      "background/classifiers/claude.js",
      "background/classifiers/openai.js",
      "background/classifiers/ollama.js",
      "background/classifier.js",
      "background/folder-manager.js",
      "background/history.js",
      "background/saga/company-registry.js",
      "background/saga/pdf-extractor.js",
      "background/saga/xml-generator.js",
      "background/saga/saga-export.js",
      "background/email-monitor.js",
      "background/background.js"
    ]
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg"
    },
    "default_title": "IncoBills",
    "default_popup": "popup/popup.html"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "messagesRead",
    "messagesMove",
    "accountsRead",
    "accountsFolders",
    "notifications",
    "storage",
    "downloads",
    "<all_urls>"
  ]
}
